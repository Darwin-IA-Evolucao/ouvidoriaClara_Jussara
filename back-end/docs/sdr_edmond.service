[Unit]
Description= Servico systemd
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/root/sdr_edmond/back-end

ExecStart=/usr/local/bin/sdr_edmond --port=3077
Restart=always
RestartSec=3
StandardOutput=append:/var/log/sdr_edmond.log
StandardError=append:/var/log/sdr_edmond.err.log

[Install]
WantedBy=multi-user.target

